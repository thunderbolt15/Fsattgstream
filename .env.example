# ─────────────────────────────────────────────
#  FastStreamBot — Environment Variables
#  Copy this to .env and fill your values
# ─────────────────────────────────────────────

# Telegram API — https://my.telegram.org
API_ID=12345678
API_HASH=your_api_hash_here

# Main Bot Token — https://t.me/BotFather
BOT_TOKEN=123456:your_bot_token_here

# Private channel ID (create one, add bot as admin)
# Forward any message to @userinfobot to get channel ID
BIN_CHANNEL=-1001234567890

# Your Railway domain (auto-filled after deploy)
# Example: https://mybot-production.up.railway.app
FQDN=https://your-railway-domain.up.railway.app

# Secret key for link signing (generate random 32 char string)
SECRET_KEY=change_this_to_a_random_secret_key_32chars

# Link expiry in hours (default 24)
LINK_EXPIRY_HOURS=24

# Server port (Railway sets this automatically)
PORT=8080

# SSL (True on Railway/Heroku, False on localhost)
HAS_SSL=True

# Optional: Extra worker bots for speed (add up to 10)
# Create more bots from @BotFather, add them to BIN_CHANNEL
# MULTI_TOKEN1=111111:worker_bot_1_token
# MULTI_TOKEN2=222222:worker_bot_2_token
# MULTI_TOKEN3=333333:worker_bot_3_token
